# Copy this file to .env.local for local development, and set the same
# values in Vercel → Project Settings → Environment Variables for preview
# and production. Never commit .env.local — it's gitignored.

# Public site URL — used for metadata, sitemap, and OpenGraph tags.
# Local dev: http://localhost:3000
# Production: your real domain once it's attached (e.g. https://southwoodumc.org)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Airtable — powers the /events page. If these are unset, the site falls
# back to showing just the two weekly Bible studies (see site-config.ts) so
# the page never looks broken pre-launch. Sign up free at airtable.com.
# API key: airtable.com/create/tokens (personal access token, needs
#   data.records:read scope on the base below)
# Base ID: found in the base's API docs URL, starts with "app..."
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Resend — powers the contact form. If these are unset, the Contact
# section shows a plain mailto/tel link instead of the form. Sign up free
# at resend.com. All three are required together.
# RESEND_FROM_EMAIL: the sending address. Use onboarding@resend.dev while
#   testing (Resend's shared sandbox sender — only delivers to your own
#   Resend account email until you verify a custom domain).
# RESEND_TO_EMAIL: where contact-form submissions actually land. This is
#   separate from the ministry's public-facing email in site-config.ts —
#   they don't have to match, e.g. this can be an internal inbox while the
#   public site shows a different address once real content arrives.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_TO_EMAIL=